{
  "$schema": "https://raw.githubusercontent.com/nicbarker/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "KILLSAY",
  "version": "0.9.99",
  "identifier": "com.killsay.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KILLSAY - Minecraft 击杀喊话脚本",
        "width": 1200,
        "height": 750,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
